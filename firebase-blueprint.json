        "name": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "read": { "type": "boolean" }
      }
    },
    "PaymentLog": {
      "title": "PaymentLog",
      "description": "Payments activity log",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Payroll": {
      "title": "Payroll",
