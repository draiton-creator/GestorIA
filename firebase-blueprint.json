        "userId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Client projects",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "budget": { "type": "number" }
      }
    },
