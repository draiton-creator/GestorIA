      "properties": {
        "userId": { "type": "string" },
        "checkIn": { "type": "object" },
        "checkOut": { "type": "object" }
      }
    },
    "Invitation": {
      "title": "Invitation",
      "description": "SaaS team dynamic invitations",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Invoice": {
      "title": "Invoice",
