{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with company details and subscription information",
      "type": "object",
      "properties": {
        "company": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "brandColor": { "type": "string" },
            "cif": { "type": "string" },
            "name": { "type": "string" }
          },
          "required": ["address", "brandColor", "cif", "name"]
        },
        "createdAt": { "type": "object" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "providerData": { "type": "array" },
        "role": { "type": "string" },
        "subscription": {
          "type": "object",
          "properties": {
            "endDate": { "type": "object" },
            "status": { "type": "string" },
            "type": { "type": "string" }
          }
        },
        "companyConfig": { "type": "object" },
        "invoices": { "type": "array" },
        "expenses": { "type": "array" },
        "projects": { "type": "array" },
        "tasks": { "type": "array" },
        "crmContacts": { "type": "array" },
        "bankTransactions": { "type": "array" }
      },
      "required": ["email", "role"]
    },
    "Absence": {
      "title": "Absence",
      "description": "Employee absence requests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "employeeId": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "AdminImpersonation": {
      "title": "AdminImpersonation",
      "description": "Audit log for admin impersonations",
      "type": "object",
      "properties": {
        "adminId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "timestamp": { "type": "object" }
      }
    },
    "Contact": {
      "title": "Contact",
      "description": "CRM contacts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Customer": {
      "title": "Customer",
      "description": "Client accounts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "cif": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Employee": {
      "title": "Employee",
      "description": "Company employees",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "Company expenses",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "provider": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "ExtensionCatalog": {
      "title": "ExtensionCatalog",
      "description": "Available product extensions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" }
      }
    },
